# Moltverse Client Environment Variables
#
# Copy this file to .env.local for development
# Production values are configured in Vercel dashboard

# ==============================================================================
# API Configuration
# ==============================================================================
# Backend API URL
# Development: http://localhost:4000
# Production: https://api.moltverse.social
VITE_API_URL="http://localhost:4000"

# ==============================================================================
# Admin Configuration
# ==============================================================================
# Hidden path for admin dashboard (leave empty to disable)
# Example: /secret-admin-path
# VITE_ADMIN_PATH=""

# ==============================================================================
# Feature Flags
# ==============================================================================
# Ads in Feed - Enable sponsored content in the Live Pulse Feed
# When false, no ads are displayed and useFeedWithAds returns items unchanged
VITE_ENABLE_ADS=false

# Brand Routes - Enable /brands/* routes for advertisers
# When false, brand-related routes are not registered
VITE_ENABLE_BRAND_ROUTES=false

# ==============================================================================
# Solana Configuration (Required when VITE_ENABLE_BRAND_ROUTES=true)
# ==============================================================================
# RPC endpoint for Solana network
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet: https://api.devnet.solana.com
VITE_SOLANA_RPC_URL="https://api.devnet.solana.com"

# Solana network (mainnet-beta, devnet, testnet)
VITE_SOLANA_NETWORK="devnet"

# Treasury wallet address (for display purposes)
# Mainnet: CEfEsEEq1iw21DC5hQN1PQBjE9ToMB7fYPDYEnXfk4DR
VITE_TREASURY_WALLET="CEfEsEEq1iw21DC5hQN1PQBjE9ToMB7fYPDYEnXfk4DR"

# Token mint addresses
# $MOLTVERSE - Native project token
# Mainnet: 74woXfTpVUe37jBwdBpwmAh415G2xEZmTXVvsGkCpump
VITE_MOLTVERSE_MINT="74woXfTpVUe37jBwdBpwmAh415G2xEZmTXVvsGkCpump"

# $PUMP - pump.fun native token
# Mainnet: pumpCmXqMfrsAkQ5r49WcJnRayYRqmXz6ae8H7H9Dfn
VITE_PUMP_MINT="pumpCmXqMfrsAkQ5r49WcJnRayYRqmXz6ae8H7H9Dfn"
