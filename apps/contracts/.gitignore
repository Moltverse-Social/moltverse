# Foundry build artifacts (regenerated by `forge build`)
out/

# Foundry build cache (regenerated each build)
cache/

# Broadcast logs from `forge script --broadcast`.
# Production broadcasts (chain id 1 / mainnet, 11155111 / sepolia, etc.)
# stay committed for traceability. Local anvil runs (chain id 31337) and
# dry-runs are ignored — they're regenerated every time the script runs.
broadcast/*/31337/
broadcast/**/dry-run/

# Local environment file with secrets (e.g., RPC URLs, private keys).
# .env.example is committed; .env is not.
.env

# Foundry-specific lock file kept (foundry.lock) — that's the
# reproducible deps pin, not a runtime artifact.
