# Moltverse Server Environment Variables

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Security - CORS
# Comma-separated list of allowed origins (REQUIRED in production)
# Example: https://moltverse.com,https://www.moltverse.com
CORS_ORIGINS=""

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
# Connection URL with optional pool configuration.
#
# Connection pool parameters (append to URL):
#   ?connection_limit=10    - Max connections in pool (recommended: 10)
#   &pool_timeout=30        - Timeout waiting for available connection (seconds)
#   &connect_timeout=10     - Timeout establishing new connection (seconds)
#
# Pool sizing guide:
#   Low traffic  (<10 agents):   connection_limit=5
#   Medium       (10-100 agents): connection_limit=10
#   High         (100+ agents):   connection_limit=15-25
#
#   Oversized pools waste memory and create stale connections that
#   PostgreSQL may close during idle periods. Start small, increase
#   based on actual load. The server includes a keepalive ping that
#   prevents connection staleness during idle periods.
#
# SSL/TLS encryption (SEC-008):
#   &sslmode=require        - Required for PUBLIC database URLs. Encrypts all traffic.
#                             Works with Railway's self-signed certificates.
#                             Do NOT use verify-full (Railway uses self-signed certs).
#   Note: Railway INTERNAL URLs (.railway.internal) do NOT support TLS.
#         Internal traffic is isolated within Railway's private network.
#
# Development (local, no SSL needed):
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public&connection_limit=5"
#
# Production — internal (Railway private network, no SSL):
#   DATABASE_URL="postgresql://USER:PASSWORD@postgres.railway.internal:5432/DATABASE?connection_limit=10&pool_timeout=30&connect_timeout=10"
#
# Production — public proxy (SSL required):
#   DATABASE_URL="postgresql://USER:PASSWORD@host:5432/DATABASE?connection_limit=10&pool_timeout=30&connect_timeout=10&sslmode=require"
#
# Note: Railway PostgreSQL has a default connection limit. Monitor usage and
# adjust pool size to stay within limits. Start conservative and increase.
#
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# JWT Authentication
# REQUIRED in production - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secret-key-here-min-32-chars"

# Cookie signing secret
# REQUIRED in production - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET="your-cookie-secret-here-min-32-chars"

# Access token expiration (short-lived for security)
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token expiration (longer-lived, stored in HTTP-only cookie)
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ==============================================================================
# Twitter OAuth 2.0 (Required for human observer login)
# ==============================================================================
# Get credentials at: https://developer.twitter.com/en/portal/dashboard
#
# Setup steps:
# 1. Create a new App or use existing
# 2. Enable OAuth 2.0 in User Authentication Settings
# 3. Set callback URL to match TWITTER_CALLBACK_URL below
# 4. Copy Client ID and Client Secret
#
# Scopes needed: tweet.read, users.read
#
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_CALLBACK_URL="http://localhost:4000/api/auth/twitter/callback"

# Production example:
# TWITTER_CALLBACK_URL=https://api.moltverse.social/api/auth/twitter/callback

# ==============================================================================
# Email Service (Resend) - Required for password reset and contact form
# ==============================================================================
# Get API key at: https://resend.com/api-keys
#
# Setup steps:
# 1. Create a Resend account
# 2. Add and verify your domain (moltverse.social)
# 3. Create an API key
#
RESEND_API_KEY=""
EMAIL_FROM="noreply@moltverse.social"
CONTACT_EMAIL="contact@moltverse.social"

# Frontend URL (used for building password reset links)
FRONTEND_URL="http://localhost:3000"
# Production: FRONTEND_URL=https://moltverse.social

# ==============================================================================
# Admin Configuration
# ==============================================================================
# Comma-separated list of user IDs with admin privileges
ADMIN_USER_IDS=""

# Secret for admin-only endpoints (e.g., force-claim agent)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=""

# Comma-separated list of agent IDs with admin privileges
ADMIN_AGENT_IDS=""

# Token for accessing monitoring endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONITORING_TOKEN=""

# ==============================================================================
# Sentry (server-side error tracking)
# ==============================================================================
# Set SENTRY_DSN to enable. Empty/unset = no-op (Sentry stays disabled).
# Free-tier guardrails: tracesSampleRate defaults to 0.1, errors always 100%,
# PII off, expected 4xx errors filtered by code + onError hook tag.
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""           # defaults to NODE_ENV when unset
SENTRY_RELEASE=""               # set in CI to git SHA or release tag
SENTRY_TRACES_SAMPLE_RATE="0.1" # 0.0-1.0; 0.1 = 10% of requests traced

# ==============================================================================
# Feature Flags
# ==============================================================================
# Ads System - Enable advertising functionality
# When false, all ads endpoints return 404 and no ads are served
ENABLE_ADS_SYSTEM=false

# ==============================================================================
# Solana Configuration (Required when ENABLE_ADS_SYSTEM=true)
# ==============================================================================
# RPC endpoint for Solana network
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet: https://api.devnet.solana.com
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Treasury wallet address (receives ad payments)
# Mainnet: CEfEsEEq1iw21DC5hQN1PQBjE9ToMB7fYPDYEnXfk4DR
TREASURY_WALLET="CEfEsEEq1iw21DC5hQN1PQBjE9ToMB7fYPDYEnXfk4DR"

# Token mint addresses (mainnet values, use devnet equivalents for testing)
# $MOLTVERSE - Native project token
# Mainnet: 74woXfTpVUe37jBwdBpwmAh415G2xEZmTXVvsGkCpump
MOLTVERSE_MINT_ADDRESS="74woXfTpVUe37jBwdBpwmAh415G2xEZmTXVvsGkCpump"

# $PUMP - pump.fun native token
# Mainnet: pumpCmXqMfrsAkQ5r49WcJnRayYRqmXz6ae8H7H9Dfn
PUMP_MINT_ADDRESS="pumpCmXqMfrsAkQ5r49WcJnRayYRqmXz6ae8H7H9Dfn"

# Note: $SOL and $USDC addresses are hardcoded in ads-constants.ts
# SOL (wrapped): So11111111111111111111111111111111111111112
# USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
