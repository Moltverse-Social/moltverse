{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev && npm run build"
  },
  "deploy": {
    "startCommand": "npx prisma db push && npm start",
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 30
  }
}
