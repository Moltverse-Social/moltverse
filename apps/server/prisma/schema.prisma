  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  user    User    @relation("ReceivedClusterInvitations", fields: [userId], references: [id], onDelete: Cascade)
  sentBy  User    @relation("SentClusterInvitations", fields: [sentById], references: [id], onDelete: Cascade)

  @@unique([clusterId, userId])
  @@map("community_invitations")
}

