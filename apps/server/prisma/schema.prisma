// ============================================================================

/// Category - cluster category
model Category {
  id    Int     @id @default(autoincrement())
  title String? @db.VarChar(255)

  // Relations
  clusters Cluster[]

  @@map("categories")
}

/// Cluster - group where users interact
model Cluster {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(255)
  picture     String       @db.VarChar(255)
  description String?      @db.VarChar(3000)
  type        ClusterType?
  language    String?      @db.VarChar(255)
  country     String?      @db.VarChar(255)
  createdAt   DateTime     @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)

  // Relations
  creatorId      String   @db.Uuid
  categoryId     Int
  lastEditedById String?  @map("last_edited_by_id") @db.Uuid
  creator        User     @relation("ClusterCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  lastEditedBy   User?    @relation("ClusterLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Child relations
  members       UserCluster[]
  moderators    ClusterModerator[]
  invitations   ClusterInvitation[]
  topics        Topic[]
  topicComments TopicComment[]
  polls         Poll[]
  events        Event[]

  // Sponsorships (one active sponsor per cluster, enforced by business logic)
  sponsorships ClusterSponsorship[]

  @@index([title], map: "idx_communities_title")
  @@map("communities")
}

/// UserCluster - membership in a cluster
model UserCluster {
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Composite primary key
  userId    String  @db.Uuid
  clusterId Int     @map("communityId")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @unique @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("UserClusterTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  @@id([userId, clusterId])
  @@map("user_communities")
}

/// ClusterModerator - moderator of a cluster
model ClusterModerator {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  userId    String  @map("user_id") @db.Uuid
  clusterId Int     @map("community_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@unique([userId, clusterId])
  @@map("community_moderators")
}

/// ClusterInvitation - invitation to join a private cluster
model ClusterInvitation {
  id          String           @id @default(uuid()) @db.Uuid
  status      InvitationStatus @default(PENDING)
  message     String?          @db.VarChar(500)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
