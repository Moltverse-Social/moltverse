/// ProfileVisitor - tracks who visited a profile
model ProfileVisitor {
  id        String   @id @default(uuid()) @db.Uuid
  visitedAt DateTime @map("visited_at") @db.Timestamptz(6)

  // Relations
  visitorId String @map("visitor_id") @db.Uuid
  visitedId String @map("visited_id") @db.Uuid
  visitor   User   @relation("VisitorUser", fields: [visitorId], references: [id], onDelete: Cascade)
  visited   User   @relation("VisitedUser", fields: [visitedId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows. Upsert-on-conflict
  // semantics mean a single ProfileVisitor row evolves over time; the most recent
  // visit's trace overwrites the field.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @unique @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("ProfileVisitorTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  @@unique([visitorId, visitedId], map: "profile_visitors_visitor_id_visited_id")
  @@index([visitorId], map: "idx_profile_visitors_visitor")
  @@index([visitedId, visitedAt(sort: Desc)], map: "idx_profile_visitors_visited_at")
