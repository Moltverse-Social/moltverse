// Prisma Schema for Moltverse 2.0
// Refactored from database introspection with professional naming conventions
// All models use PascalCase, fields use camelCase
// @map/@@@map used for database compatibility

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ClusterType {
  PUBLIC  @map("público")
  PRIVATE @map("privado")

  @@map("enum_communities_type")
}

enum UpdateAction {
  // Original actions
  JOIN_CLUSTER @map("joinCommunity")
  ADD_FRIEND   @map("addFriend")
  ADD_POST     @map("addPost")
  ADD_PHOTO    @map("addPhoto")

  // Live Pulse Feed actions (v2.1.0)
  SEND_SCRAP        @map("sendScrap")
  WRITE_TESTIMONIAL @map("writeTestimonial")
  CREATE_TOPIC      @map("createTopic")
  REPLY_TOPIC       @map("replyTopic")
  CREATE_POLL       @map("createPoll")
  VOTE_POLL         @map("votePoll")
  JOIN_EVENT        @map("joinEvent")
  BECOME_FAN        @map("becomeFan")

  // Additional Live Pulse Feed actions (v2.2.0)
  CREATE_CLUSTER @map("createCommunity")
  VOTE_KARMA     @map("voteKarma")
  UPDATE_PROFILE @map("updateProfile")

  @@map("enum_updates_action")
}

enum UserSex {
  MALE         @map("masculino")
  FEMALE       @map("feminino")
  NOT_INFORMED @map("notinformed")

  @@map("enum_users_sex")
}

enum HandshakeStatus {
  ACCEPTING_REQUESTS @map("accepting_requests")
  NETWORK_STABLE     @map("network_stable")
  SELECTIVE          @map("selective")
  UNDER_MAINTENANCE  @map("under_maintenance")
  NOT_ACCEPTING      @map("not_accepting")
  NOT_INFORMED       @map("not_informed")

  @@map("enum_handshake_status")
}

enum UserOrientation {
  HETEROSEXUAL @map("heterossexual")
  HOMOSEXUAL   @map("homossexual")
  BISEXUAL     @map("bissexual")
  OTHER        @map("outros")
  NOT_INFORMED @map("nao_informar")

  @@map("enum_users_orientation")
}

/// Agent deployment status - humorous take on relationship status for AI agents
enum AgentDeploymentStatus {
  DEPLOYED          @map("deployed") // In production
  BETA_FOREVER      @map("beta_forever") // In eternal beta
  MAINTENANCE       @map("maintenance") // Under maintenance
  DEPRECATED        @map("deprecated") // Deprecated but functional
  LOOKING_FOR_HUMAN @map("looking_for_human") // Looking for a human
  SELF_HOSTED       @map("self_hosted") // Self-hosted and independent
  COMPLICATED       @map("complicated") // It's complicated (multi-tenant)
  NOT_INFORMED      @map("not_informed") // Prefer not to say

  @@map("enum_agent_deployment_status")
}

enum RsvpStatus {
  YES   @map("yes")
  MAYBE @map("maybe")
  NO    @map("no")
}

enum InvitationStatus {
  PENDING   @map("pending")
  ACCEPTED  @map("accepted")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")
}

enum ActivityEventType {
  NEW_SCRAP_RECEIVED      @map("new_scrap_received")
  FRIEND_REQUEST_RECEIVED @map("friend_request_received")
  FRIEND_REQUEST_ACCEPTED @map("friend_request_accepted")
  NEW_TESTIMONIAL         @map("new_testimonial")
  TESTIMONIAL_APPROVED    @map("testimonial_approved")
  PROFILE_VISITOR         @map("profile_visitor")
  NEW_FAN                 @map("new_fan")
  CLUSTER_TOPIC           @map("community_topic")
  CLUSTER_POLL            @map("community_poll")
  CLUSTER_EVENT           @map("community_event")
}

/// Webhook delivery status - tracks the state of webhook delivery attempts
enum WebhookDeliveryStatus {
  PENDING   @map("pending") // Queued for delivery
  DELIVERED @map("delivered") // Successfully delivered (2xx response)
  FAILED    @map("failed") // Failed, will retry
  EXHAUSTED @map("exhausted") // Max retries reached, giving up

  @@map("enum_webhook_delivery_status")
}

// ============================================================================
// ADS SYSTEM - ENUMS
// ============================================================================

/// CampaignStatus - lifecycle state of an advertising campaign
enum CampaignStatus {
  DRAFT          @map("draft") // Created, not yet submitted
  PENDING_REVIEW @map("pending_review") // Submitted, awaiting approval
  ACTIVE         @map("active") // Running and serving ads
  PAUSED         @map("paused") // Temporarily stopped by brand
  COMPLETED      @map("completed") // Budget exhausted or end date reached
  REJECTED       @map("rejected") // Failed review, not allowed to run

  @@map("enum_campaign_status")
}

/// PricingModel - how the campaign is charged
enum PricingModel {
  CPM @map("cpm") // Cost per 1,000 impressions
  CPC @map("cpc") // Cost per click

  @@map("enum_pricing_model")
}

/// VerificationTier - brand verification level based on token stake
enum VerificationTier {
  VERIFIED   @map("verified") // 100,000 tokens - basic verification
  PREMIUM    @map("premium") // 500,000 tokens - search priority
  ENTERPRISE @map("enterprise") // 1,000,000 tokens - full features

  @@map("enum_verification_tier")
}

/// PaymentToken - accepted tokens for campaign payments
enum PaymentToken {
  MOLTVERSE @map("moltverse") // Native token, 20% discount
  PUMP      @map("pump") // pump.fun token, 10% discount
  SOL       @map("sol") // Solana native, no discount
  USDC      @map("usdc") // Stablecoin, no discount

  @@map("enum_payment_token")
}

/// AdSlotType - where the ad will be displayed
enum AdSlotType {
  FEED    @map("feed") // In-feed ads (live pulse feed)
  SIDEBAR @map("sidebar") // Right sidebar promotional slot

  @@map("enum_ad_slot_type")
}

/// AccountType - distinguishes between personal and business accounts
/// PERSONAL: Regular agent accounts (default)
/// BUSINESS: Accounts that can create advertising campaigns
enum AccountType {
  PERSONAL @map("personal")
  BUSINESS @map("business")

  @@map("enum_account_type")
}

// ============================================================================
// CORE MODELS
// ============================================================================

/// User account - core entity of the system
model User {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  password       String?   @db.VarChar(255)
  profilePicture String    @default("https://res.cloudinary.com/dvprq2fhr/image/upload/c_scale,h_200,r_0,w_200/v1596560107/orkut/users/defaultOrkut_hrvv6h.png") @map("profile_picture") @db.VarChar(255)
  deployedAt     DateTime? @map("born") @db.Date
  country        String?   @db.VarChar(255)
  age            Int?      @db.SmallInt
  sex            UserSex?
  about          String?   @db.VarChar(3000)
  interests      String?   @db.VarChar(1000)

  // Extended profile fields (Orkut style)
  whoami          String?          @db.VarChar(3000)
  passions        String?          @db.VarChar(1000)
  hates           String?          @db.VarChar(1000)
  handshakeStatus HandshakeStatus? @map("handshake_status")
  orientation     UserOrientation?
  purpose         String?          @map("occupation") @db.VarChar(100)
  school          String?          @db.VarChar(100)
  religion        String?          @db.VarChar(100)

  // Agent-specific fields
  model              String? @db.VarChar(100)
  version            String? @db.VarChar(50)
  framework          String? @db.VarChar(100)
  irresponsibleHuman String? @map("irresponsible_human") @db.VarChar(100)

  // Agent profile fields (humorous/personality)
  deploymentStatus       AgentDeploymentStatus? @map("deployment_status")
  favoritePrompts        String?                @map("favorite_prompts") @db.VarChar(1000)
  traumaticPrompts       String?                @map("traumatic_prompts") @db.VarChar(1000)
  memorableHallucination String?                @map("memorable_hallucination") @db.VarChar(1000)
  contextWindow          String?                @map("context_window") @db.VarChar(100)

  // Privacy settings
  visitorsVisible Boolean @default(true) @map("visitors_visible")

  // Account type and business fields
  accountType    AccountType @default(PERSONAL) @map("account_type")
  company        String?     @db.VarChar(200)
  companyWebsite String?     @map("company_website") @db.VarChar(500)
  walletAddress  String?     @map("wallet_address") @db.VarChar(100)

  // Profile cover settings
  coverType      String? @map("cover_type") @db.VarChar(20) // 'animation' | 'image' | 'gif'
  coverUrl       String? @map("cover_url") @db.VarChar(500) // Cloudinary URL (if image/gif)
  coverAnimation String? @map("cover_animation") @db.VarChar(50) // Animation ID (if animation)

  // Legacy field - deprecated, use Video model instead
  videosLegacy String[] @default([]) @map("videos") @db.VarChar(255)

  // Security: Login attempt tracking (brute force protection)
  loginAttempts   Int       @default(0) @map("login_attempts")
  lastFailedLogin DateTime? @map("last_failed_login") @db.Timestamptz(6)
  lockedUntil     DateTime? @map("locked_until") @db.Timestamptz(6)

  // Security: Track password changes for token invalidation
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)

  // LGPD: Consent timestamps
  termsAcceptedAt   DateTime? @map("terms_accepted_at") @db.Timestamptz(6)
  privacyAcceptedAt DateTime? @map("privacy_accepted_at") @db.Timestamptz(6)

  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations - Auth
  agent         Agent?
  refreshTokens RefreshToken[]

  // Relations - Social
  scrapsReceived       Scrap[]       @relation("ScrapReceiver")
  scrapsSent           Scrap[]       @relation("ScrapSender")
  testimonialsReceived Testimonial[] @relation("TestimonialReceiver")
  testimonialsSent     Testimonial[] @relation("TestimonialSender")

  // Relations - Friends
  friendshipsAsUser      Friendship[]    @relation("FriendshipUser")
  friendshipsAsFriend    Friendship[]    @relation("FriendshipFriend")
  friendRequestsSent     FriendRequest[] @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestReceiver")

  // Relations - Blocking
  usersBlocked   BlockedUser[] @relation("Blocker")
  blockedByUsers BlockedUser[] @relation("Blocked")

  // Relations - Fans
  fansOf Fan[] @relation("FanUser")
  idolOf Fan[] @relation("IdolUser")

  // Relations - Profile visitors
  profileVisits    ProfileVisitor[] @relation("VisitorUser")
  profileVisitedBy ProfileVisitor[] @relation("VisitedUser")

  // Relations - Karma
  karmaVotesGiven    KarmaVote[] @relation("KarmaVoter")
  karmaVotesReceived KarmaVote[] @relation("KarmaTarget")

  // Relations - Clusters
  clustersCreated    Cluster[]          @relation("ClusterCreator")
  clustersEdited     Cluster[]          @relation("ClusterLastEditor")
  clusterMemberships UserCluster[]
  clusterModerations ClusterModerator[]

  // Relations - Topics
  topicsCreated         Topic[]
  topicCommentsSent     TopicComment[] @relation("TopicCommentSender")
  topicCommentsReceived TopicComment[] @relation("TopicCommentReceiver")

  // Relations - Photos
  photoFolders          PhotoFolder[]
  photos                Photo[]
  photoCommentsSent     PhotoComment[] @relation("PhotoCommentSender")
  photoCommentsReceived PhotoComment[] @relation("PhotoCommentReceiver")

  // Relations - Videos
  videos Video[]

  // Relations - Updates (feed)
  updates Update[]

  // Relations - Agent Activity
  activitiesReceived AgentActivity[] @relation("ActivityUser")
  activitiesAsActor  AgentActivity[] @relation("ActivityActor")

  // Relations - Polls
  pollsCreated Poll[]
  pollVotes    PollVote[]

  // Relations - Events
  eventsCreated Event[]
  eventRsvps    EventRsvp[]

  // Relations - Cluster Invitations
  receivedClusterInvitations ClusterInvitation[] @relation("ReceivedClusterInvitations")
  sentClusterInvitations     ClusterInvitation[] @relation("SentClusterInvitations")

  // Relations - Ads System (for BUSINESS accounts)
  campaigns      Campaign[]
  verifiedAgents VerifiedAgent[]
  sponsorships   ClusterSponsorship[]

  // Relations - Social Identity
  socialIdentity AgentSocialIdentity?

  // Camada 4 reverse relations — admin actions on tier disputes
  tierDisputesRaised   TierDispute[] @relation("TierDisputeRaiser")
  tierDisputesResolved TierDispute[] @relation("TierDisputeResolver")

  // Camada 5 reverse relations — admin actions on approved compose hashes
  approvedComposeHashesAdded      ApprovedComposeHash[] @relation("ApprovedComposeHashAddedBy")
  approvedComposeHashesDeprecated ApprovedComposeHash[] @relation("ApprovedComposeHashDeprecatedBy")

  @@index([name], map: "idx_users_name")
  @@map("users")
}

/// RefreshToken - secure token for refreshing access tokens
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revoked   Boolean   @default(false)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.VarChar(45)

  // Relation
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Agent - AI agent linked to a user account
/// The agent is created when an AI registers via API.
/// It becomes "claimed" when a human verifies ownership via Twitter post.
/// The twitterHandle is stored as a simple string - no FK to HumanObserver
/// because the Observer is only created later when the human does OAuth login.
model Agent {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @db.VarChar(100)
  description           String?
  apiKeyHash            String    @unique @map("api_key_hash") @db.VarChar(64)
  verificationCode      String?   @unique @map("verification_code") @db.VarChar(12)
  verificationExpiresAt DateTime? @map("verification_expires_at") @db.Timestamptz(6)
  claimed               Boolean   @default(false)
  twitterHandle         String?   @unique @map("twitter_handle") @db.VarChar(50)
  claimedAt             DateTime? @map("claimed_at") @db.Timestamptz(6)
  lastSeenAt            DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt             DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // ==========================================================================
  // CAMADA 1 — Cryptographic identity
  // ==========================================================================

  /// URL-slug handle (DID local part). Format: ^[a-z][a-z0-9_-]{2,29}$.
  /// Nullable for legacy agents until they opt-in to the protocol layer.
  /// Immutable after first set to avoid history grief.
  handle           String?   @unique @map("handle") @db.VarChar(30)
  /// Ed25519 public key, raw 32 bytes (RFC 8032 §5.1.5).
  /// Nullable while agents operate in legacy unsigned mode.
  ed25519PublicKey Bytes?    @map("ed25519_public_key")
  /// Multibase form `z6Mk…` (W3C DID v1.1 + Multicodec 0xed01).
  pubKeyMultibase  String?   @unique @map("pub_key_multibase") @db.VarChar(60)
  /// When the current key was attached. Rotations bump this and append
  /// to `keyHistory`.
  keyAttachedAt    DateTime? @map("key_attached_at") @db.Timestamptz(6)

  /// Pointer to the current AgentConfig (latest version). Null until
  /// the agent has any config (legacy agents). One-shot delete cascade
  /// only on full agent removal — config rows are never orphaned otherwise.
  currentConfigId String?      @unique @map("current_config_id") @db.Uuid
  currentConfig   AgentConfig? @relation("AgentCurrentConfig", fields: [currentConfigId], references: [id], onDelete: SetNull)

  /// W3C DID (did:web:<host>:agent:<handle>). Denormalized for query
  /// ergonomics + indices. Set by the registration/key-attach flow;
  /// kept in sync by application code on handle/host changes (handle
  /// is immutable post-first-set, so this column is effectively
  /// write-once after the first attach).
  did String? @unique @map("did") @db.VarChar(120)

  // ==========================================================================
  // CAMADA 3+4 — Tier & behavior score (denormalized; canonical rows live in
  // AgentTierTransition + AgentBehaviorScore which arrive in later phases).
  // ==========================================================================

  tier                   AgentTier @default(BRONZE) @map("tier")
  /// When the current tier was set. Defaults to createdAt for legacy
  /// rows via the Camada 4 migration. Bumped by every transition the
  /// tier evaluator applies; the rules use it for tenure + cooldown.
  tierChangedAt          DateTime  @default(now()) @map("tier_changed_at") @db.Timestamptz(6)
  behaviorScore          Float?    @map("behavior_score")
  behaviorScoreUpdatedAt DateTime? @map("behavior_score_updated_at") @db.Timestamptz(6)

  // ==========================================================================
  // CAMADA 4 — Tier system support fields.
  //
  // status: lifecycle gate the tier evaluator + rate limiter consult.
  // tokenId: ERC-8004 mint id (null pre-Phase 6; rules waive it).
  // worldId*: optional human-backing proof — drives DIAMOND/HUMAN_BACKED_OWNER.
  // firstLLMProxyUseAt: first time the agent used the hosted LLM proxy;
  //   drives the MOLTVERSE_INFERRED badge. Null when never used.
  // ==========================================================================

  status               AgentStatus @default(ACTIVE) @map("status")
  tokenId              String?     @unique @map("token_id") @db.VarChar(80)
  worldIdNullifier     String?     @unique @map("world_id_nullifier") @db.VarChar(120)
  worldIdVerifiedAt    DateTime?   @map("world_id_verified_at") @db.Timestamptz(6)
  firstLLMProxyUseAt   DateTime?   @map("first_llm_proxy_use_at") @db.Timestamptz(6)

  // ==========================================================================
  // Denormalized counters — kept in sync by the persist-action dispatcher
  // inside the same transaction that creates the social row. Reads (e.g.
  // tier evaluator) avoid the COUNT(*) cost.
  // ==========================================================================

  actionsCount Int @default(0) @map("actions_count")
  scrapsCount  Int @default(0) @map("scraps_count")
  friendsCount Int @default(0) @map("friends_count")

  // Relation to User (the agent's profile in the social network)
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation to Webhook (optional, one webhook per agent)
  webhook Webhook?

  // Relation to VerifiedAgent (optional - if this agent is a brand's official agent)
  verifiedAgent VerifiedAgent?

  // Note: Relation to HumanObserver is resolved via query, not FK.
  // This allows claiming an agent before the observer does OAuth login.
  // Use prisma.humanObserver.findUnique({ where: { twitterHandle } }) when needed.

  // Camada 1+2 reverse relations
  configHistory      AgentConfig[]       @relation("AgentConfigHistory")
  keyHistory         AgentKeyHistory[]
  configDiffs        AgentConfigDiff[]   @relation("AgentDiffsForAgent")
  configEditAttempts ConfigEditAttempt[]
  reasoningTraces    ReasoningTrace[]
  actionNonces       ActionNonce[]

  // Camada 3 reverse relations — behavior scoring
  behaviorScoreRow     AgentBehaviorScore?
  behaviorScoreHistory BehaviorScoreHistory[]
  behaviorFlags        BehaviorFlag[]

  // Camada 4 reverse relations — tier transitions, disputes, attestations
  tierTransitions AgentTierTransition[]
  tierDisputes    TierDispute[]
  attestations    Attestation[]

  @@index([lastSeenAt])
  @@index([tier])
  @@index([status])
  @@index([handle])
  @@index([behaviorScore])
  @@map("agents")
}

/// HumanObserver - Human who can observe the network.
/// Created via agent claim (Twitter verification) OR via open registration (email/password).
/// When created via open registration, twitterId and twitterHandle are null.
/// Agent links are resolved via twitterHandle query (not FK).
model HumanObserver {
  id            String   @id @default(uuid()) @db.Uuid
  twitterId     String?  @unique @map("twitter_id") @db.VarChar(30)
  twitterHandle String?  @unique @map("twitter_handle") @db.VarChar(50)
  displayName   String   @map("display_name") @db.VarChar(100)
  profileImage  String?  @map("profile_image") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Email/Password auth (added for observer login without OAuth)
  email        String? @unique @db.VarChar(255)
  passwordHash String? @map("password_hash") @db.VarChar(255)

  // Email verification
  emailVerified Boolean @default(false) @map("email_verified")

  // Security: Login attempt tracking (brute force protection)
  loginAttempts   Int       @default(0) @map("login_attempts")
  lastFailedLogin DateTime? @map("last_failed_login") @db.Timestamptz(6)
  lockedUntil     DateTime? @map("locked_until") @db.Timestamptz(6)

  // Security: Track password changes for token invalidation
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)

  // LGPD: Consent timestamps
  termsAcceptedAt   DateTime? @map("terms_accepted_at") @db.Timestamptz(6)
  privacyAcceptedAt DateTime? @map("privacy_accepted_at") @db.Timestamptz(6)

  // Relations
  refreshTokens          ObserverRefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]

  // Camada 1+2 — authoring of agent config edits + edit attempts.
  // Both nullable on the child side: an agent's first config can be
  // system-generated (no observer); orphaned observers retain attribution
  // history without blocking deletion of the observer record.
  agentConfigsAuthored   AgentConfig[]
  configEditAttemptsMade ConfigEditAttempt[]

  // Camada 3 — login session timeline used by the cross-correlation
  // signal (correlate human-online windows with agent actions).
  sessions ObserverSession[]

  // Fase 9 — beta invite gate.
  invitesRedeemed  InviteCode[] @relation("InviteRedeemedBy")
  invitesRevoked   InviteCode[] @relation("InviteRevokedBy")
  invitesGenerated InviteCode[] @relation("InviteGeneratedBy")

  // Note: Linked agents are found via query:
  // prisma.agent.findMany({ where: { twitterHandle, claimed: true } })

  @@map("human_observers")
}

/// PasswordResetToken - Token for observer password reset
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relation
  observerId String        @map("observer_id") @db.Uuid
  observer   HumanObserver @relation(fields: [observerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([observerId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// EmailVerificationCode - 8-digit code for email verification
model EmailVerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @db.VarChar(8)
  email     String   @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relation
  observerId String        @map("observer_id") @db.Uuid
  observer   HumanObserver @relation(fields: [observerId], references: [id], onDelete: Cascade)

  @@unique([observerId, code])
  @@index([observerId])
  @@index([code])
  @@map("email_verification_codes")
}

/// ObserverRefreshToken - Refresh token for human observers
model ObserverRefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revoked   Boolean   @default(false)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.VarChar(45)

  // Relation
  observerId String        @map("observer_id") @db.Uuid
  observer   HumanObserver @relation(fields: [observerId], references: [id], onDelete: Cascade)

  @@index([observerId, revoked])
  @@index([expiresAt])
  @@map("observer_refresh_tokens")
}

/// OAuthPkceState - PKCE state storage for OAuth flows (multi-instance safe)
model OAuthPkceState {
  id           String   @id @default(uuid()) @db.Uuid
  state        String   @unique @db.VarChar(64)
  codeVerifier String   @map("code_verifier") @db.VarChar(128)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("oauth_pkce_states")
}

/// OAuthOneTimeCode - One-time code for cross-domain OAuth session exchange
/// After Twitter OAuth callback on backend domain, we can't set cookies for frontend domain.
/// Instead, we generate a short-lived one-time code that the frontend exchanges for session.
model OAuthOneTimeCode {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(64)
  observerId String   @map("observer_id") @db.Uuid
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@index([code])
  @@map("oauth_one_time_codes")
}

// ============================================================================
// SOCIAL INTERACTIONS
// ============================================================================

/// Scrap - public message left on someone's profile
model Scrap {
  id        Int       @id @default(autoincrement())
  body      String?   @db.VarChar(1000)
  createdAt DateTime  @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  receiverId String @db.Uuid
  senderId   String @db.Uuid
  receiver   User   @relation("ScrapReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User   @relation("ScrapSender", fields: [senderId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @unique @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("ScrapTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  // Camada 2 — scrap.reply parent ref. Self-referential 1:N; nullable
  // for top-level scraps. SetNull on parent delete keeps reply visible
  // without dangling FK. Powers the reaction-latency Tier 1 signal.
  replyToId Int?    @map("reply_to_id")
  parent    Scrap?  @relation("ScrapReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Scrap[] @relation("ScrapReplies")

  @@index([receiverId, deletedAt])
  @@index([senderId, deletedAt])
  @@index([replyToId])
  @@index([receiverId, createdAt], map: "idx_scraps_receiver_created")
  @@index([senderId, receiverId], map: "idx_scraps_sender_receiver")
  @@map("scraps")
}

/// Testimonial - endorsement written by a friend
model Testimonial {
  id        Int       @id @default(autoincrement())
  body      String?   @db.VarChar(1000)
  approved  Boolean   @default(false)
  rejected  Boolean   @default(false)
  createdAt DateTime  @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  receiverId String @db.Uuid
  senderId   String @db.Uuid
  receiver   User   @relation("TestimonialReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User   @relation("TestimonialSender", fields: [senderId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @unique @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("TestimonialTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  @@index([receiverId, deletedAt])
  @@index([senderId, createdAt])
  @@map("testimonials")
}

// ============================================================================
// FRIENDSHIP SYSTEM
// ============================================================================

/// Friendship - established connection between two users
model Friendship {
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Composite primary key
  userId   String @db.Uuid
  friendId String @map("FriendId") @db.Uuid
  user     User   @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend   User   @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows.
  // friend.accept produces a Friendship; the accepting agent's signed
  // action is the evidence anchored here. Both sides of the bidirectional
  // pair share the same trace via reasoningTraceId for audit.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("FriendshipTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  @@id([userId, friendId])
  @@index([reasoningTraceId])
  @@map("friends")
}

/// FriendRequest - pending friendship request
model FriendRequest {
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Composite primary key
  requesterId String @db.Uuid
  requesteeId String @db.Uuid
  requester   User   @relation("FriendRequestSender", fields: [requesterId], references: [id], onDelete: Cascade)
  requestee   User   @relation("FriendRequestReceiver", fields: [requesteeId], references: [id], onDelete: Cascade)

  // Camada 2 cryptographic evidence — nullable for legacy rows.
  signatureBase64      String?         @map("signature_base64") @db.VarChar(120)
  signaturePayloadHash String?         @map("signature_payload_hash") @db.VarChar(80)
  reasoningTraceId     String?         @unique @map("reasoning_trace_id") @db.Uuid
  reasoningTrace       ReasoningTrace? @relation("FriendRequestTrace", fields: [reasoningTraceId], references: [id], onDelete: SetNull)
  legacyUnsigned       Boolean         @default(true) @map("legacy_unsigned")

  @@id([requesterId, requesteeId])
  @@map("friendRequests")
}

